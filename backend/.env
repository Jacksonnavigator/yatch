# ── App ─────────────────────────────────────────────────────
APP_NAME="Rock The Yatch Booking"
ENVIRONMENT=production
FRONTEND_URL=http://localhost:3000

# ── Security ─────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=sqlite:///./yacht_booking.db

# ── Email (SMTP) ──────────────────────────────────────────────
MAIL_USERNAME=jacksonnavigator7@gmail.com
MAIL_PASSWORD=123456.Ja
MAIL_FROM=noreply@rockttheyatch.com
MAIL_FROM_NAME="Rock The Yatch"
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=True
MAIL_SSL_TLS=False

# ── Owner Account (auto-created on first run) ─────────────────
OWNER_EMAIL=owner@rockttheyatch.com
OWNER_PASSWORD=SecureOwnerPass123!
OWNER_NAME="Yacht Owner"

# ── File Uploads ──────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
